{
  "permissions": {
    "deny": [
      "Read(**/kubeconfig)",
      "Read(**/*.kubeconfig)",
      "Read(**/talosconfig)",
      "Read(**/identity)",
      "Read(**/age.key)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/.netrc)",
      "Read(**/.pgpass)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Read(**/*.agekey)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.crt)",
      "Read(**/*.csr)",
      "Read(**/.terraform/**)",
      "Read(**/*.tfstate)",
      "Read(**/*.tfstate.*)",
      "Read(**/*.tfvars)",
      "Read(**/*.tfvars.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/deny-secret-paths.sh"
          }
        ]
      }
    ]
  }
}
